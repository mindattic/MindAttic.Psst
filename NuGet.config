<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      Local source is optional — used by the maintainer for pre-publish testing
      of MindAttic.* packages. If C:\LocalNuGet doesn't exist on your machine
      that's fine: NuGet silently ignores missing local sources.
      Override in a user-level NuGet.config if you need a different path.
    -->
    <add key="local" value="C:\LocalNuGet" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
